{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "all3rounds",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "env": {
    "development": {
      "name": "all3rounds-dev",
      "vars": {
        "APP_ENV": "development"
      },
      "images": {
        "binding": "IMAGES"
      }
    },
    "production": {
      "name": "all3rounds",
      "vars": {
        "APP_ENV": "production"
      },
      "images": {
        "binding": "IMAGES"
      }
    }
  }
}
