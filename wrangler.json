{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "all3rounds",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "all3rounds-dev",
      "database_id": "ad631ab8-6830-4f81-956b-6d7b068d5a79",
      "migrations_dir": "migrations"
    }
  ],
  "observability": {
    "enabled": true
  },
  "env": {
    "development": {
      "name": "all3rounds-dev",
      "vars": {
        "APP_ENV": "development"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "all3rounds-dev",
          "database_id": "ad631ab8-6830-4f81-956b-6d7b068d5a79",
          "migrations_dir": "migrations"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "SEARCH_CACHE",
          "id": "19c74e3d6ba949f8be24193f0a134d10"
        }
      ],
      "images": {
        "binding": "IMAGES"
      }
    },
    "production": {
      "name": "all3rounds",
      "vars": {
        "APP_ENV": "production"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "all3rounds",
          "database_id": "32e50e6a-4344-4591-98d3-dd26e6c35aff",
          "migrations_dir": "migrations"
        }
      ],
      "images": {
        "binding": "IMAGES"
      }
    }
  }
}
