{
  "name": "all3rounds",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:cf": "pnpm build:wp",
    "build:wp": "wrangler d1 migrations apply DB --local && next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "preview:dev": "pnpm build:wp && wrangler dev --env development --local",
    "preview:prod": "pnpm build:wp && wrangler dev --env production --remote",
    "deploy:dev": "pnpm build:wp && wrangler deploy --env development",
    "deploy:prod": "pnpm build:wp && wrangler deploy --env production",
    "migrate:export": "tsx scripts/migration/export-postgres.ts",
    "migrate:transform": "tsx scripts/migration/transform-to-sqlite.ts",
    "migrate:verify": "tsx scripts/migration/verify-parity.ts",
    "migrate:build-import": "tsx scripts/migration/build-d1-import.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.1",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^26.1.0",
    "msw": "^2.8.4",
    "pg": "^8.21.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.1",
    "wrangler": "^4.76.0"
  }
}
